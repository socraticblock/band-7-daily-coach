# OpenAI (or any OpenAI-compatible) API for AI feedback
# Required for production feedback. Without this, the API returns a structured mock.
OPENAI_API_KEY=

# Model choice
OPENAI_MODEL=gpt-4o-mini

# Speech-to-text (Whisper or compatible)
# Without this, speaking transcribe route returns a placeholder.
OPENAI_STT_MODEL=whisper-1

# TTS provider choice
# openai | elevenlabs | azure (set per listening script metadata)
TTS_PROVIDER=openai
